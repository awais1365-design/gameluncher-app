{
  "name": "gameluncher-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && ELECTRON_ENV=development electron .\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "electron:compile": "tsc -p electron/tsconfig.json && node -e \"require('fs').writeFileSync('electron/dist/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "electron:build": "npm run electron:compile && npm run build",
    "electron:pack": "npm run electron:build && electron-builder --dir",
    "electron:dist": "npm run electron:build && electron-builder",
    "electron:publish": "npm run electron:build && electron-builder --publish always",
    "electron:test-update": "npm run electron:compile && SIMULATE_UPDATE=1 electron ."
  },
  "dependencies": {
    "@nestjs/mongoose": "^11.0.4",
    "adm-zip": "^0.5.17",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "6.8.3",
    "mongoose": "^9.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "wait-on": "^9.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron-builder": "^26.8.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  },
  "build": {
    "appId": "com.gameluncher.app",
    "productName": "GameLauncher",
    "copyright": "Copyright © 2025 GameLauncher",
    "asar": true,
    "asarUnpack": [
      "node_modules/electron-updater/**"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "electron/**",
      "!electron/updater/**",
      "package.json"
    ],
    "extraResources": [],
    "publish": {
      "provider": "github",
      "owner": "awais1365-design",
      "repo": "gamelauncher-app",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.games",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "sign": false,
      "writeUpdateInfo": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "GameLauncher"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Game"
    }
  }
}
